# ==============================================
# BERLINLABS.DIGITAL - Environment Variables
# ==============================================
# Copy this file to .env.local for local development
# DO NOT commit .env files to the repository

# ==============================================
# FRONTEND CONFIGURATION
# ==============================================
# API Base URL (optional, for future API integrations)
VITE_API_BASE_URL=https://api.berlinlabs.studio

# ==============================================
# BACKEND CONFIGURATION (Vercel Serverless)
# ==============================================
# Supabase Configuration (for contact/onboarding forms)
# Get these from: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# CORS Allowed Origins (comma-separated list)
ALLOWED_ORIGINS=https://berlinlabs.digital,https://www.berlinlabs.digital

# ==============================================
# DEPLOYMENT NOTES
# ==============================================
# Set these in Vercel Dashboard (Settings → Environment Variables):
# - SUPABASE_URL
# - SUPABASE_SERVICE_ROLE_KEY
# - ALLOWED_ORIGINS
