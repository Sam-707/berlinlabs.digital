# ============================================
# GEMINI AI CONFIGURATION
# ============================================
# Get your API key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ============================================
# SUPABASE CONFIGURATION
# ============================================
# Get these from: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-anon-key-here

# ============================================
# EVOLUTION API CONFIGURATION
# ============================================
# Evolution API secret used by the container and your app
EVOLUTION_API_TOKEN=change-me-very-strong-token

# Domain you point to nginx (update nginx.conf accordingly)
# Example: https://wa.your-domain.com
EVOLUTION_API_URL=https://wa.your-domain.com

# Evolution instance name (from Evolution manager)
EVOLUTION_INSTANCE=instance-name
