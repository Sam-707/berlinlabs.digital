# Environment Variables Template for 3rbst WhatsApp Bot

# AI/OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here

# Twilio Configuration
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Supabase Database Configuration  
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# PayPal Configuration (for future payment integration)
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_MODE=sandbox  # or 'live' for production

# System Configuration
NODE_ENV=development  # or 'production'

# Instructions:
# 1. Copy this file to .env: cp .env.template .env
# 2. Fill in your actual credentials
# 3. Never commit .env to version control
# 4. In Vercel Dashboard, add these as Environment Variables