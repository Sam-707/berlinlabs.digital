# 3rbst Platform Environment Variables
# Copy to .env.local and fill in your actual values

# Twilio WhatsApp Business API
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+your_number_here

# Supabase Database
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# OpenAI (GDPR Compliant)
OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_ORG_ID=org-your_organization_id

# Google Cloud Vision OCR
GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account","project_id":"your-project",...}

# Vercel Analytics
VERCEL_ANALYTICS_ID=your_vercel_analytics_id

# Production Settings
NODE_ENV=production
WEBHOOK_URL=https://your-domain.vercel.app/api/webhook

# Security
ADMIN_PASSWORD=your_secure_admin_password_here

# PayPal Payment Integration (Required for premium features)
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here

# Optional: Stripe (placeholder for future)
# STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
# STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key

# Business Information
BUSINESS_NAME=3rbst
BUSINESS_EMAIL=hello@3rbst.com
BUSINESS_PHONE=+49-your-phone
BUSINESS_ADDRESS=Your Address, Germany
