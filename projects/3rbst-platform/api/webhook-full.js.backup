// Main webhook handler
module.exports = async (req, res) => {
    console.log('🚀 Clean Webhook v3.0 - Fresh Start');
    
    // CORS headers
    res.setHeader('Access-Control-Allow-Origin', '*');
    res.setHeader('Access-Control-Allow-Methods', 'GET, POST, OPTIONS');
    res.setHeader('Access-Control-Allow-Headers', 'Content-Type, Authorization');
    
    if (req.method === 'OPTIONS') {
        return res.status(200).send('OK');
    }
    
    if (req.method !== 'POST') {
        return res.status(405).json({ error: 'Method not allowed' });
    }

    try {
        const { From, Body, MessageSid, NumMedia, MediaUrl0 } = req.body;

        if (!From || !MessageSid) {
            return res.status(400).json({ error: 'Invalid webhook data' });
        }

        const fromNumber = From.replace('whatsapp:', '');
        const hasMedia = NumMedia && parseInt(NumMedia) > 0;

        console.log(`📱 Message from: ${fromNumber}`);
        console.log(`📸 Has media: ${hasMedia}`);

        // Check GDPR consent first (required by German/EU law)
        const consentStatus = await checkUserConsent(fromNumber);
        console.log(`🔒 Consent status:`, consentStatus);
        
        // If user hasn't given consent, request it
        if (!consentStatus.hasConsent) {
            if (consentStatus.isNewUser) {
                // New user - request consent
                responseMessage = getConsentRequestMessage();
                
                // Send consent request
                const sentMessage = await client.messages.create({
                    body: responseMessage,
                    from: whatsappNumber,
                    to: From
                });
                
                console.log('🔒 GDPR consent request sent:', sentMessage.sid);
                return res.status(200).json({
                    success: true,
                    messageSid: sentMessage.sid,
                    action: 'gdpr_consent_required',
                    version: 'clean-v3.1'
                });
            } else {
                // Existing user without consent - handle their response
                const consentResponse = await handleConsentResponse(fromNumber, Body);
                
                if (!consentResponse.consentProcessed) {
                    // Unclear response - ask again
                    const sentMessage = await client.messages.create({
                        body: consentResponse.message,
                        from: whatsappNumber,
                        to: From
                    });
                    
                    return res.status(200).json({
                        success: true,
                        messageSid: sentMessage.sid,
                        action: 'gdpr_consent_clarification',
                        version: 'clean-v3.1'
                    });
                } else if (!consentResponse.consentGiven) {
                    // User refused consent
                    const sentMessage = await client.messages.create({
                        body: consentResponse.message,
                        from: whatsappNumber,
                        to: From
                    });
                    
                    return res.status(200).json({
                        success: true,
                        messageSid: sentMessage.sid,
                        action: 'gdpr_consent_refused',
                        version: 'clean-v3.1'
                    });
                } else {
                    // User gave consent - send confirmation and continue
                    const sentMessage = await client.messages.create({
                        body: consentResponse.message,
                        from: whatsappNumber,
                        to: From
                    });
                    
                    return res.status(200).json({
                        success: true,
                        messageSid: sentMessage.sid,
                        action: 'gdpr_consent_granted',
                        version: 'clean-v3.1'
                    });
                }
            }
        }
        
        // User has valid consent - proceed with service
        // Check if user can analyze documents (usage limits)
        const userStatus = await checkUserCanAnalyze(fromNumber);
        console.log(`👤 User status:`, userStatus);

        // Initialize Twilio
        const accountSid = process.env.TWILIO_ACCOUNT_SID;
        const authToken = process.env.TWILIO_AUTH_TOKEN;
        const whatsappNumber = process.env.TWILIO_WHATSAPP_NUMBER || 'whatsapp:+14155238886';

        if (!accountSid || !authToken) {
            return res.status(500).json({ error: 'Twilio not configured' });
        }

        const client = twilio(accountSid, authToken);
        let responseMessage;

        if (hasMedia && MediaUrl0) {
            console.log('📄 Processing document...');
            console.log('📸 Original Media URL:', MediaUrl0);
            
            // Check if user can analyze this document
            if (!userStatus.canAnalyze) {
                console.log('❌ User has no credits left');
                responseMessage = getPaymentRequiredMessage(fromNumber);
                
                // Send payment required message
                const sentMessage = await client.messages.create({
                    body: responseMessage,
                    from: whatsappNumber,
                    to: From
                });
                
                console.log('💳 Payment required message sent:', sentMessage.sid);
                return res.status(200).json({
                    success: true,
                    messageSid: sentMessage.sid,
                    action: 'payment_required',
                    version: 'clean-v3.1'
                });
            }
            
            // Send immediate confirmation
            const confirmationMessage = `🔸 *عربست* | 🤖 *جاري التحليل...* 

✅ *تم استقبال الوثيقة بنجاح!*

🧠 جاري تحليل الوثيقة بالذكاء الاصطناعي...
⏱️ سيتم الرد خلال 30-60 ثانية

*من فضلك انتظر...*

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
🤖 *عربست AI*
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━`;

            // Send confirmation first
            await client.messages.create({
                body: confirmationMessage,
                from: whatsappNumber,
                to: From
            });
            
            console.log('✅ Confirmation sent, now processing...');
            
            // Download media from Twilio with authentication and convert to base64
            try {
                console.log('🔐 Fetching authenticated media from Twilio...');
                
                // Get media with Twilio authentication
                const mediaResponse = await fetch(MediaUrl0, {
                    headers: {
                        'Authorization': `Basic ${Buffer.from(`${accountSid}:${authToken}`).toString('base64')}`
                    }
                });
                
                if (!mediaResponse.ok) {
                    throw new Error(`Media fetch failed: ${mediaResponse.status} ${mediaResponse.statusText}`);
                }
                
                // Convert to base64 for GPT-4 Vision
                const mediaBuffer = await mediaResponse.arrayBuffer();
                const mediaBase64 = Buffer.from(mediaBuffer).toString('base64');
                const contentType = mediaResponse.headers.get('content-type') || 'image/jpeg';
                
                console.log('✅ Media downloaded and converted to base64');
                console.log('📊 Media size:', Math.round(mediaBuffer.byteLength / 1024), 'KB');
                console.log('🖼️ Content type:', contentType);
                
                // Create data URL for GPT-4 Vision
                const dataUrl = `data:${contentType};base64,${mediaBase64}`;
                
                const startTime = Date.now();
                responseMessage = await analyzeDocument(dataUrl);
                const processingTime = Date.now() - startTime;
                
                // Record usage in database
                await recordUsage(
                    fromNumber, 
                    MessageSid, 
                    userStatus.isFree, 
                    'document', 
                    responseMessage,
                    processingTime
                );
                
                console.log(`📊 Usage recorded: ${userStatus.isFree ? 'FREE' : 'PAID'} (${processingTime}ms)`);
                
            } catch (mediaError) {
                console.error('❌ Media processing error:', mediaError);
                responseMessage = `⚠️ *عذراً، حدثت مشكلة تقنية*

🔧 *المشكلة:*
لم أتمكن من تحميل الصورة من WhatsApp

💡 *الحلول المقترحة:*
• أرسل الصورة مرة أخرى
• تأكد من وضوح الصورة
• جرب التقاط صورة جديدة
• تأكد من اتصال الإنترنت

🔄 *جرب مرة أخرى* - أنا جاهز لمساعدتك!

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
🤖 *تم بواسطة عربست AI*
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━`;
                
                // Still record the failed attempt if user had credits
                if (userStatus.canAnalyze) {
                    await recordUsage(fromNumber, MessageSid, userStatus.isFree, 'error', responseMessage, 0);
                }
            }
        } else {
            // Handle text messages (greetings, payment requests, etc.)
            const messageText = (Body || '').toLowerCase().trim();
            
            // Check for payment requests
            if (messageText.includes('شراء') || messageText.includes('رصيد') || messageText.includes('دفع')) {
                console.log('💳 Payment request detected');
                responseMessage = generatePaymentRequestMessage();
            }
            // Handle specific plan requests
            else if (messageText.includes('basic') || messageText === '5') {
                console.log('💳 Basic plan requested');
                responseMessage = await createPaymentLinkForUser(fromNumber, 'basic');
            }
            else if (messageText.includes('premium') || messageText === '15') {
                console.log('💳 Premium plan requested');
                responseMessage = await createPaymentLinkForUser(fromNumber, 'premium');
            }
            else if (messageText.includes('unlimited') || messageText.includes('غير محدود') || messageText === '25') {
                console.log('💳 Unlimited plan requested');
                responseMessage = await createPaymentLinkForUser(fromNumber, 'unlimited');
            }
            // Default greeting
            else {
                responseMessage = `🔸 *عربست* | 🤖 *AI POWERED* 🔸

*مرحباً! أنا عربست، مساعدك الذكي للوثائق الألمانية* 👋

╔══════════════════════════╗
║ 📋 *كيف أساعدك؟* ║
╚══════════════════════════╝

أرسل صورة أي وثيقة ألمانية وسأحللها لك فوراً:

✅ *وثائق الضرائب* (Finanzamt)
✅ *الرسائل القانونية* (Gericht/Polizei)
✅ *المستندات الطبية* (Krankenkasse)
✅ *الفواتير والمطالبات* (Rechnung/Mahnung)
✅ *أي وثيقة رسمية أخرى*

💡 *${userStatus.canAnalyze ? 
    (userStatus.isFree ? 'لديك وثيقة مجانية للتجربة!' : `لديك ${userStatus.remainingCredits} وثائق متبقية`) : 
    'تم استهلاك رصيدك - أرسل "أريد شراء رصيد"'
}*

📸 *أرسل الصورة الآن!*

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
🤖 *عربست AI* - تحليل ذكي للوثائق الألمانية
*دقة • سرعة • احترافية*
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━`;
            }
        }

        // Send WhatsApp response
        const sentMessage = await client.messages.create({
            body: responseMessage,
            from: whatsappNumber,
            to: From
        });

        console.log('✅ Response sent:', sentMessage.sid);

        return res.status(200).json({
            success: true,
            messageSid: sentMessage.sid,
            userStatus: {
                canAnalyze: userStatus.canAnalyze,
                isFree: userStatus.isFree,
                remainingCredits: userStatus.remainingCredits
            },
            version: 'clean-v3.1',
            timestamp: new Date().toISOString()
        });

    } catch (error) {
        console.error('❌ Webhook error:', error);
        return res.status(500).json({
            error: 'Internal server error',
            version: 'clean-v3.1'
        });
    }
};

