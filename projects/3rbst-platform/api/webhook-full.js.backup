🔒 *حماية كاملة للبيانات*

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
🤖 *عربست AI* - اختر رقم الخطة المناسبة
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━`;
}

// Helper function to create payment link for user
async function createPaymentLinkForUser(fromNumber, planId) {
    try {
        const plan = PAYMENT_PLANS[planId];
        if (!plan) {
            return `❌ *خطة غير صالحة*

أرسل "أريد شراء رصيد" لعرض الخطط المتاحة.`;
        }
        
        console.log(`💳 Creating payment order for ${fromNumber}, plan: ${planId}`);
        
        const paymentOrder = await createPaymentOrder(planId, fromNumber);
        
        if (!paymentOrder.success) {
            console.error('❌ Payment order creation failed:', paymentOrder.error);
            return `❌ *خطأ في إنشاء رابط الدفع*

حاول مرة أخرى أو تواصل معنا.`;
        }
        
        return `🔸 *عربست* | 💳 *تأكيد الطلب*

╔══════════════════════════╗
║ 🛍️ *تفاصيل طلبك* ║
╚══════════════════════════╝

📦 **الخطة:** ${plan.name}
💰 **السعر:** €${plan.price}
📄 **عدد الوثائق:** ${plan.documents === 999999 ? 'غير محدود' : plan.documents}
⏰ **الصلاحية:** ${plan.duration_days ? plan.duration_days + ' يوم' : 'حسب الاستخدام'}

🔗 **رابط الدفع الآمن:**
${paymentOrder.approval_url}

💡 **تعليمات:**
1️⃣ اضغط على الرابط أعلاه
2️⃣ ادفع بأمان عبر PayPal
3️⃣ ارجع إلى WhatsApp
4️⃣ ابدأ في استخدام رصيدك فوراً!

🔒 *دفع آمن 100%*
⚡ *تفعيل فوري*
✅ *ضمان استرداد المال*

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
🤖 *عربست AI* - Order ID: ${paymentOrder.order_id}
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━`;
        
    } catch (error) {
        console.error('❌ Error creating payment link:', error);
        return `❌ *خطأ تقني*

حدث خطأ أثناء إنشاء رابط الدفع. حاول مرة أخرى أو تواصل معنا.`;
    }
}